[0m23:55:49.242520 [debug] [Thread-3 (]: On model.sales_dbt.monthly_revenue: /* {"app": "dbt", "dbt_version": "1.11.8", "profile_name": "sales_dbt", "target_name": "dev", "node_id": "model.sales_dbt.monthly_revenue"} */

  
    

  create  table "sales_db"."gold"."monthly_revenue__dbt_tmp"
  
  
    as
  
  (
    with orders as (
    select * from "sales_db"."silver"."fct_orders"
),

monthly as (
    select
        date_trunc('month', order_date)::date   as month,
        count(order_id)                         as total_orders,
        sum(total_items)                        as total_items,
        sum(total_amount)                       as gross_revenue,
        sum(discounted_amount)                  as net_revenue,
        round(avg(discounted_amount), 2)        as avg_ticket
    from orders
    group by 1
)

select
    *,
    round(
        (net_revenue - lag(net_revenue) over (order by month))
        * 100.0
        / nullif(lag(net_revenue) over (order by month), 0),
    2) as mom_growth_pct
from monthly
order by month
  );
  
